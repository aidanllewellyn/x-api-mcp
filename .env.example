# Server
PORT=3000
HOST=127.0.0.1
MCP_PATH=/mcp
# Idle MCP sessions are closed after this many milliseconds. Default: 30 minutes.
# MCP_SESSION_TTL_MS=1800000

# Optional: require local MCP clients to send Authorization: Bearer <token>
# MCP_BEARER_TOKEN=<generate-random-token>

# X API auth option 1: OAuth 2.0 user-context access token.
# Required scopes depend on enabled tools. For bookmark/like reads, use:
# tweet.read users.read bookmark.read like.read
# X_USER_ACCESS_TOKEN=

# Optional: OAuth 2.0 refresh credentials. If set, an expired access token is
# refreshed automatically on a 401 instead of failing the request.
# X_OAUTH2_REFRESH_TOKEN=
# X_OAUTH2_CLIENT_ID=
# X_OAUTH2_CLIENT_SECRET=

# Optional: authenticated user's numeric X ID. Set this to avoid an extra
# /2/users/me lookup before bookmark/like owned-read requests.
# X_USER_ID=

# X API auth option 2: OAuth 1.0a user-context credentials.
# X_API_KEY=
# X_API_KEY_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# Optional read backend for public read helpers.
# auto keeps X API credentials as the default, then uses Hermes Tweet when no X
# credentials are configured and HERMES_TWEET_API_KEY or XQUIK_API_KEY exists.
# Set to x, hermes, or xquik to force a backend.
# X_API_MCP_READ_BACKEND=auto
# HERMES_TWEET_API_KEY=
# HERMES_TWEET_BASE_URL=https://xquik.com
# HERMES_TWEET_TIMEOUT_MS=30000
# XQUIK_API_KEY=
# XQUIK_BASE_URL=https://xquik.com
