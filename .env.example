# Server
PORT=3000
HOST=127.0.0.1
MCP_PATH=/mcp
# Idle MCP sessions are closed after this many milliseconds. Default: 30 minutes.
# MCP_SESSION_TTL_MS=1800000

# Optional: require local MCP clients to send Authorization: Bearer <token>
# MCP_BEARER_TOKEN=<generate-random-token>

# X API auth option 1: OAuth 2.0 user-context access token.
# Required scopes depend on enabled tools. For bookmark/like reads, use:
# tweet.read users.read bookmark.read like.read
# X_USER_ACCESS_TOKEN=

# Optional: authenticated user's numeric X ID. Set this to avoid an extra
# /2/users/me lookup before bookmark/like owned-read requests.
# X_USER_ID=

# X API auth option 2: OAuth 1.0a user-context credentials.
# X_API_KEY=
# X_API_KEY_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
